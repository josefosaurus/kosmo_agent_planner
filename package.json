{
  "name": "kosmo-sidekick",
  "displayName": "Kosmo Sidekick",
  "description": "Spec-driven development with Claude Code CLI. Generate requirements, design, and tasks from a goal — then run each task as an isolated AI agent.",
  "version": "0.3.0",
  "publisher": "josefosaurus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josefosaurus/kosmo_agent_planner"
  },
  "icon": "kosmo.png",
  "galleryBanner": {
    "color": "#0f0f0f",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "claude",
    "spec",
    "tasks",
    "agent",
    "kiro",
    "productivity"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kosmo.newSpec",
        "title": "Kosmo: New Spec",
        "icon": "$(add)"
      },
      {
        "command": "kosmo.startTask",
        "title": "Kosmo: Start Task",
        "icon": "$(play)"
      },
      {
        "command": "kosmo.killTask",
        "title": "Kosmo: Kill Task",
        "icon": "$(debug-stop)"
      },
      {
        "command": "kosmo.refreshTasks",
        "title": "Kosmo: Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "kosmo.selectCli",
        "title": "Kosmo: Select AI CLI",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kosmo.discover",
        "title": "Kosmo: Discover",
        "icon": "$(search)"
      }
    ],
    "configuration": {
      "title": "Kosmo",
      "properties": {
        "kosmo.specCli": {
          "type": "string",
          "default": "",
          "description": "AI CLI binary to use for spec generation (e.g. claude, gemini, codex). Auto-detected if empty."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "kosmoTasks",
          "name": "Kosmo Tasks",
          "icon": "$(checklist)",
          "contextualTitle": "Kosmo Tasks"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "kosmo.specEditor",
        "displayName": "Kosmo Spec Viewer",
        "selector": [
          {
            "filenamePattern": "**/.kosmo/specs/**/requirements.md"
          },
          {
            "filenamePattern": "**/.kosmo/specs/**/design.md"
          },
          {
            "filenamePattern": "**/.kosmo/specs/**/tasks.md"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kosmo.newSpec",
          "when": "view == kosmoTasks",
          "group": "navigation@1"
        },
        {
          "command": "kosmo.refreshTasks",
          "when": "view == kosmoTasks",
          "group": "navigation@2"
        },
        {
          "command": "kosmo.discover",
          "when": "view == kosmoTasks",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "kosmo.startTask",
          "when": "view == kosmoTasks && viewItem == pendingTask",
          "group": "inline"
        },
        {
          "command": "kosmo.killTask",
          "when": "view == kosmoTasks && viewItem == inprogressTask",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/test/suite.test.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "package": "vsce package --no-dependencies",
    "screenshots": "node scripts/take-screenshots.mjs"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0"
  }
}