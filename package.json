{
  "name": "kosmo-sidekick",
  "displayName": "Kosmo Sidekick",
  "description": "Spec-driven development with Claude Code CLI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kosmo.newSpec",
        "title": "Kosmo: New Spec",
        "icon": "$(add)"
      },
      {
        "command": "kosmo.startTask",
        "title": "Kosmo: Start Task",
        "icon": "$(play)"
      },
      {
        "command": "kosmo.killTask",
        "title": "Kosmo: Kill Task",
        "icon": "$(debug-stop)"
      },
      {
        "command": "kosmo.refreshTasks",
        "title": "Kosmo: Refresh Tasks",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "kosmoTasks",
          "name": "Kosmo Tasks",
          "icon": "$(checklist)",
          "contextualTitle": "Kosmo Tasks"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kosmo.newSpec",
          "when": "view == kosmoTasks",
          "group": "navigation@1"
        },
        {
          "command": "kosmo.refreshTasks",
          "when": "view == kosmoTasks",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "kosmo.startTask",
          "when": "view == kosmoTasks && viewItem == pendingTask",
          "group": "inline"
        },
        {
          "command": "kosmo.killTask",
          "when": "view == kosmoTasks && viewItem == inprogressTask",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0"
  }
}
